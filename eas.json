{
  "cli": {
    "version": ">= 5.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "staging": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "ios": {
        "buildConfiguration": "Release"
      },
      "env": {
        "NODE_ENV": "staging",
        "APP_VARIANT": "staging",
        "EXPO_PUBLIC_FIREBASE_PROJECT_ID": "furgokid-staging",
        "SENTRY_ENABLED": "true",
        "SENTRY_ENVIRONMENT": "staging",
        "FIREBASE_ANALYTICS_ENABLED": "true",
        "ENABLE_DEBUG_MENU": "true",
        "ENABLE_DEBUG_LOGS": "true"
      },
      "channel": "staging"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "ios": {
        "buildConfiguration": "Release"
      },
      "env": {
        "NODE_ENV": "production",
        "APP_VARIANT": "preview",
        "SENTRY_ENABLED": "false",
        "FIREBASE_ANALYTICS_ENABLED": "false"
      },
      "channel": "preview"
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease"
      },
      "ios": {
        "distribution": "store"
      },
      "env": {
        "NODE_ENV": "production",
        "APP_VARIANT": "production",
        "SENTRY_ENABLED": "true",
        "FIREBASE_ANALYTICS_ENABLED": "false",
        "EXPO_PUBLIC_ADS_MODE": "production",
        "EXPO_PUBLIC_ADS_FORCE_TEST": "0"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      }
    }
  }
}
