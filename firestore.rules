rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================================
    // HELPER FUNCTIONS
    // ============================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRole(role) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function isAdmin() {
      return hasRole('admin');
    }
    
    function isDriver() {
      return hasRole('driver');
    }
    
    function isParent() {
      return hasRole('parent');
    }
    
    // Prevent role escalation
    function roleUnchanged() {
      return request.resource.data.role == resource.data.role;
    }
    
    // ============================================================================
    // RATE LIMITING FUNCTIONS (Big Tech Standard)
    // ============================================================================
    
    // Check if enough time has passed since last write (prevents spam)
    function rateLimit(cooldownSeconds) {
      return !('lastModified' in resource.data) || 
             request.time > resource.data.lastModified + duration.value(cooldownSeconds, 's');
    }
    
    // Check if user hasn't exceeded daily limit
    function dailyLimit(limitCount) {
      let today = request.time.toMillis() / 86400000; // Days since epoch
      let lastUpdate = resource.data.get(['rateLimitDay'], 0);
      let count = resource.data.get(['rateLimitCount'], 0);
      
      // Reset counter if it's a new day
      return (today > lastUpdate) || (count < limitCount);
    }
    
    // Validate request size (prevent large document spam)
    function validRequestSize() {
      return request.resource.size() < 1000000; // 1MB max document size
    }
    
    // Ensure required fields for rate limiting are set
    function setRateLimitFields() {
      let today = request.time.toMillis() / 86400000;
      let isNewDay = !('rateLimitDay' in resource.data) || 
                      (request.time.toMillis() / 86400000) > resource.data.rateLimitDay;
      
      return request.resource.data.lastModified == request.time &&
             request.resource.data.rateLimitDay == today &&
             request.resource.data.rateLimitCount == (isNewDay ? 1 : resource.data.rateLimitCount + 1);
    }
    
    // ============================================================================
    // USERS COLLECTION
    // ============================================================================
    
    match /users/{userId} {
      // Anyone authenticated can read their own profile or admin can read all
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile during registration
      allow create: if isAuthenticated() && 
                      isOwner(userId) &&
                      validRequestSize();
      
      // Users can update their own profile but cannot change their role
      // Rate limit: max 1 update per minute (prevent spam)
      allow update: if isOwner(userId) && 
                      roleUnchanged() &&
                      rateLimit(60) &&
                      validRequestSize();
      
      // Only admins can delete users
      allow delete: if isAdmin();
    }
    
    // ============================================================================
    // ROUTES COLLECTION
    // ============================================================================
    
    match /routes/{routeId} {
      // Anyone authenticated can read routes
      allow read: if isAuthenticated();
      
      // Only drivers can create routes
      // Rate limit: max 10 routes per day
      allow create: if isDriver() &&
                      validRequestSize();
      
      // Only the route owner (driver) can update their routes
      // Rate limit: max 1 update per 5 minutes
      allow update: if isDriver() && 
                      resource.data.driverId == request.auth.uid &&
                      rateLimit(300) &&
                      validRequestSize();
      
      // Only route owner or admin can delete
      allow delete: if isAdmin() || 
                      (isDriver() && resource.data.driverId == request.auth.uid);
    }
    
    // ============================================================================
    // TRACKING POINTS COLLECTION
    // ============================================================================
    
    match /trackingPoints/{pointId} {
      // Anyone authenticated can read tracking points
      allow read: if isAuthenticated();
      
      // Only drivers can create/update tracking points
      // Rate limit: max 1 per 5 seconds (prevent GPS spam)
      allow create, update: if isDriver() &&
                              rateLimit(5) &&
                              validRequestSize();
      
      // Only admin can delete
      allow delete: if isAdmin();
    }
    
    // ============================================================================
    // REQUESTS COLLECTION
    // ============================================================================
    
    match /requests/{requestId} {
      // Users can read requests where they are parent or driver
      allow read: if isAuthenticated() && (
        resource.data.parentId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      
      // Only parents can create requests
      // Rate limit: max 20 requests per day
      allow create: if isParent() &&
                      validRequestSize();
      
      // Parents and drivers can update requests (for status changes)
      // Rate limit: max 1 update per minute
      allow update: if isAuthenticated() && (
        resource.data.parentId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      ) && rateLimit(60) && validRequestSize();
      
      // Only parent who created or admin can delete
      allow delete: if isAdmin() || 
                      (isParent() && resource.data.parentId == request.auth.uid);
    }
    
    // ============================================================================
    // VACANCIES COLLECTION
    // ============================================================================
    
    match /vacancies/{vacancyId} {
      // Anyone authenticated can read vacancies
      allow read: if isAuthenticated();
      
      // Only drivers can create vacancies
      // Rate limit: max 5 vacancies per day
      allow create: if isDriver() &&
                      validRequestSize();
      
      // Only the driver who created can update
      // Rate limit: max 1 update per 10 minutes
      allow update: if isDriver() && 
                      resource.data.driverId == request.auth.uid &&
                      rateLimit(600) &&
                      validRequestSize();
      
      // Only owner or admin can delete
      allow delete: if isAdmin() || 
                      (isDriver() && resource.data.driverId == request.auth.uid);
    }
    
    // ============================================================================
    // MATCHES COLLECTION
    // ============================================================================
    
    match /matches/{matchId} {
      // Users can read matches where they are involved
      allow read: if isAuthenticated() && (
        resource.data.parentId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      
      // System/admin creates matches
      allow create: if isAdmin();
      
      // No updates allowed (immutable)
      allow update: if false;
      
      // Only admin can delete
      allow delete: if isAdmin();
    }
    
    // ============================================================================
    // NOTIFICATIONS COLLECTION
    // ============================================================================
    
    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isAuthenticated() && 
                    resource.data.userId == request.auth.uid;
      
      // Only backend/cloud functions can write notifications
      allow write: if false;
    }
    
    // ============================================================================
    // CHAT/MESSAGES COLLECTION (if implemented)
    // ============================================================================
    
    match /chats/{chatId} {
      // Users can read chats they are part of
      allow read: if isAuthenticated() && 
                    request.auth.uid in resource.data.participants;
      
      // Users can create chats
      allow create: if isAuthenticated() && 
                      request.auth.uid in request.resource.data.participants;
      
      // Only participants can update (send messages)
      allow update: if isAuthenticated() && 
                      request.auth.uid in resource.data.participants;
      
      // Only admin can delete chats
      allow delete: if isAdmin();
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() && 
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && 
                        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow update, delete: if false;
      }
    }
  }
}