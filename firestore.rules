rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================================
    // HELPER FUNCTIONS
    // ============================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRole(role) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function isAdmin() {
      return hasRole('admin');
    }
    
    function isDriver() {
      return hasRole('driver');
    }
    
    function isParent() {
      return hasRole('parent');
    }
    
    // Prevent role escalation
    function roleUnchanged() {
      return request.resource.data.role == resource.data.role;
    }
    
    // ============================================================================
    // USERS COLLECTION
    // ============================================================================
    
    match /users/{userId} {
      // Anyone authenticated can read their own profile or admin can read all
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile during registration
      allow create: if isAuthenticated() && isOwner(userId);
      
      // Users can update their own profile but cannot change their role
      allow update: if isOwner(userId) && roleUnchanged();
      
      // Only admins can delete users
      allow delete: if isAdmin();
    }
    
    // ============================================================================
    // ROUTES COLLECTION
    // ============================================================================
    
    match /routes/{routeId} {
      // Anyone authenticated can read routes
      allow read: if isAuthenticated();
      
      // Only drivers can create routes
      allow create: if isDriver();
      
      // Only the route owner (driver) can update their routes
      allow update: if isDriver() && 
                      resource.data.driverId == request.auth.uid;
      
      // Only route owner or admin can delete
      allow delete: if isAdmin() || 
                      (isDriver() && resource.data.driverId == request.auth.uid);
    }
    
    // ============================================================================
    // TRACKING POINTS COLLECTION
    // ============================================================================
    
    match /trackingPoints/{pointId} {
      // Anyone authenticated can read tracking points
      allow read: if isAuthenticated();
      
      // Only drivers can create/update tracking points
      allow create, update: if isDriver();
      
      // Only admin can delete
      allow delete: if isAdmin();
    }
    
    // ============================================================================
    // REQUESTS COLLECTION
    // ============================================================================
    
    match /requests/{requestId} {
      // Users can read requests where they are parent or driver
      allow read: if isAuthenticated() && (
        resource.data.parentId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      
      // Only parents can create requests
      allow create: if isParent();
      
      // Parents and drivers can update requests (for status changes)
      allow update: if isAuthenticated() && (
        resource.data.parentId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      
      // Only parent who created or admin can delete
      allow delete: if isAdmin() || 
                      (isParent() && resource.data.parentId == request.auth.uid);
    }
    
    // ============================================================================
    // VACANCIES COLLECTION
    // ============================================================================
    
    match /vacancies/{vacancyId} {
      // Anyone authenticated can read vacancies
      allow read: if isAuthenticated();
      
      // Only drivers can create vacancies
      allow create: if isDriver();
      
      // Only the driver who created can update
      allow update: if isDriver() && resource.data.driverId == request.auth.uid;
      
      // Only owner or admin can delete
      allow delete: if isAdmin() || 
                      (isDriver() && resource.data.driverId == request.auth.uid);
    }
    
    // ============================================================================
    // MATCHES COLLECTION
    // ============================================================================
    
    match /matches/{matchId} {
      // Users can read matches where they are involved
      allow read: if isAuthenticated() && (
        resource.data.parentId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      
      // System/admin creates matches
      allow create: if isAdmin();
      
      // No updates allowed (immutable)
      allow update: if false;
      
      // Only admin can delete
      allow delete: if isAdmin();
    }
    
    // ============================================================================
    // NOTIFICATIONS COLLECTION
    // ============================================================================
    
    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isAuthenticated() && 
                    resource.data.userId == request.auth.uid;
      
      // Only backend/cloud functions can write notifications
      allow write: if false;
    }
    
    // ============================================================================
    // CHAT/MESSAGES COLLECTION (if implemented)
    // ============================================================================
    
    match /chats/{chatId} {
      // Users can read chats they are part of
      allow read: if isAuthenticated() && 
                    request.auth.uid in resource.data.participants;
      
      // Users can create chats
      allow create: if isAuthenticated() && 
                      request.auth.uid in request.resource.data.participants;
      
      // Only participants can update (send messages)
      allow update: if isAuthenticated() && 
                      request.auth.uid in resource.data.participants;
      
      // Only admin can delete chats
      allow delete: if isAdmin();
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() && 
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && 
                        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow update, delete: if false;
      }
    }
  }
}