#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🎨 Running lint-staged (auto-format & lint)..."

npx lint-staged

if [ $? -ne 0 ]; then
  echo "❌ Lint-staged failed. Fix errors and try again."
  exit 1
fi

echo "🔍 Validando configuración de Expo antes del commit..."

# Validar que app.config.js no tenga errores de sintaxis
npx expo config --type public > /dev/null 2>&1

if [ $? -ne 0 ]; then
  echo "❌ ERROR: app.config.js tiene errores de sintaxis"
  echo "Ejecuta: npx expo config --type public para ver detalles"
  exit 1
fi

echo "✅ app.config.js válido"

# Validar que no se estén commiteando secrets
echo "🔐 Verificando que no se commiteen secrets..."

if git diff --cached --name-only | grep -q "^\.env$"; then
  echo "❌ ERROR: Intentando commitear .env"
  echo "Los secrets NO deben ir a Git. Usa EAS Secrets para producción."
  exit 1
fi

# Verificar que no haya API keys hardcodeadas
if [ "$ALLOW_POSSIBLE_KEYS" != "1" ]; then
  # Excluir archivos que normalmente contienen API keys públicas o textos (evita falsos positivos)
  # - google-services.json / GoogleService-Info.plist: contienen config pública de Firebase
  # - docs/**: documentación puede incluir ejemplos/formatos
  if git diff --cached -U0 -- . ':(exclude)google-services.json' ':(exclude)**/GoogleService-Info.plist' ':(exclude)docs/**' \
    | grep -E '^\+' \
    | grep -v -E '^\+\+\+' \
    | grep -E "(AIza[0-9A-Za-z_-]{35}|AAAA[0-9A-Za-z_:-]{100,}|ca-app-pub-[0-9]{16})"; then
    echo "❌ ERROR: Se detectaron posibles API keys hardcodeadas en cambios staged"
    echo "Revisa y elimina keys del código (usa .env / EAS Secrets / GitHub Secrets)."
    echo "Si es intencional (no recomendado), reintenta con: ALLOW_POSSIBLE_KEYS=1 git commit ..."
    exit 1
  fi
else
  echo "⚠️  WARNING: ALLOW_POSSIBLE_KEYS=1 habilitado; se omitió bloqueo por posibles keys"
fi

echo "✅ Validación de seguridad completada"
exit 0
