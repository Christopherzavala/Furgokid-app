{
  "name": "furgokid",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx --max-warnings 0",
    "lint:fix": "eslint src --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run lint && npm run test",
    "validate:env": "node scripts/validate-env.js",
    "validate:env:production": "node scripts/validate-env.js --mode production",
    "validate:ids": "node scripts/validate-identifiers.js",
    "validate:secrets": "node scripts/validate-sensitive-literals.js",
    "pre-build": "npm run validate && npm run validate:env && npm run validate:ids && npm run validate:secrets && npm audit --audit-level=low",
    "pre-build:prod": "npm run validate && npm run validate:ids && npm run validate:secrets && npm run validate:env:production && npm audit --audit-level=low",
    "emulators": "powershell -ExecutionPolicy Bypass -File ./scripts/start-emulators.ps1",
    "smoke:test": "node scripts/smoke-tests.js",
    "deploy:staging": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-staging.ps1",
    "rollback": "powershell -ExecutionPolicy Bypass -File ./scripts/rollback.ps1",
    "monitor:health": "node scripts/monitor-health.js",
    "pre-deploy": "powershell -ExecutionPolicy Bypass -File ./scripts/pre-deploy-check.ps1",
    "quick:setup": "powershell -ExecutionPolicy Bypass -File ./scripts/quick-setup.ps1",
    "build:staging": "eas build --platform android --profile staging",
    "build:preview": "eas build --platform android --profile preview",
    "build:production": "eas build --platform android --profile production",
    "build:local": "eas build --platform android --profile preview --local",
    "security:audit": "powershell -ExecutionPolicy Bypass -File ./scripts/security-audit.ps1",
    "eas:migrate": "powershell -ExecutionPolicy Bypass -File ./scripts/migrate-to-eas.ps1",
    "eas:migrate:dry": "powershell -ExecutionPolicy Bypass -File ./scripts/migrate-to-eas.ps1 -DryRun",
    "validate:config": "npx expo config --type public",
    "prepare": "node -e \"try { require('husky').install() } catch (e) { if (e.code !== 'MODULE_NOT_FOUND') throw e }\"",
    "doctor": "npx expo-doctor",
    "analyze:bundle": "node scripts/analyze-bundle.js",
    "e2e:build:android": "detox build --configuration android.debug",
    "e2e:test:android": "detox test --configuration android.debug",
    "e2e:build:ios": "detox build --configuration ios.debug",
    "e2e:test:ios": "detox test --configuration ios.debug"
  },
  "dependencies": {
    "@expo/cli": "^54.0.20",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^6.5.8",
    "@react-navigation/native": "^6.1.7",
    "@react-navigation/stack": "^6.3.17",
    "@sentry/react-native": "~6.1.0",
    "dotenv": "^17.2.3",
    "expo": "^54.0.30",
    "expo-constants": "~18.0.10",
    "expo-dev-client": "~6.0.18",
    "expo-device": "^8.0.10",
    "expo-font": "~14.0.9",
    "expo-linear-gradient": "~15.0.7",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.13",
    "expo-secure-store": "^15.0.8",
    "expo-splash-screen": "~31.0.11",
    "expo-status-bar": "~3.0.8",
    "expo-task-manager": "~14.0.9",
    "expo-updates": "~29.0.16",
    "firebase": "^12.7.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-fast-image": "^8.6.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.0.1",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-toast-message": "^2.2.0",
    "react-native-vector-icons": "^10.0.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/eslint-parser": "^7.28.5",
    "@react-native-community/eslint-config": "^3.2.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "~19.1.10",
    "@types/react-native-vector-icons": "^6.4.14",
    "@typescript-eslint/parser": "^8.51.0",
    "babel-preset-expo": "^54.0.7",
    "chalk": "^4.1.2",
    "detox": "^20.46.3",
    "eslint": "^8.44.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-plugin-jest": "^27.9.0",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.13",
    "lint-staged": "^13.2.3",
    "prettier": "^2.8.8",
    "typescript": "^5.1.3"
  },
  "overrides": {
    "micromatch": "4.0.8",
    "undici": "6.23.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ],
    "functions/**/*.js": [
      "cd functions && npm run lint -- --fix"
    ]
  },
  "private": true
}
